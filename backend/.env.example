# Database — defaults to local SQLite so the API runs with zero setup.
# For Postgres (as recommended in the PRD), use:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/fariba
DATABASE_URL=sqlite:///./fariba.db

SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:3000

# Integration keys (stubbed in this scaffold)
JAZZCASH_MERCHANT_ID=
EASYPAISA_STORE_ID=
STRIPE_SECRET_KEY=
TWILIO_WHATSAPP_FROM=
